# PostgreSQL (used by docker-compose and the Spring Boot backend)
POSTGRES_DB=authdb
POSTGRES_USER=auth
POSTGRES_PASSWORD=auth
POSTGRES_PORT=5434

# Spring Boot datasource (defaults match docker-compose above)
DATABASE_URL=jdbc:postgresql://localhost:5434/authdb
DATABASE_USER=auth
DATABASE_PASSWORD=auth
JPA_DDL_AUTO=update

# JWT
JWT_SECRET=change-me-to-a-long-random-base64-string
